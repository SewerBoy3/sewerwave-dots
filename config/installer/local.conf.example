# Copiá a config/installer/local.conf — ver CONFIG.md

[workflows]
webdev=1
gamedev=0
audio=1
webdev_antigravity=0
webdev_nodejs=1

[system]
login_method=startx
zram_size=ram/2
zram_swappiness=180
aur_helper=auto
change_shell=1

[browser]
browser=brave

[desktop]
enable_picom=1
enable_polybar=1
fastfetch_on_terminal=1
zellij_autostart=0

[i3]
gaps_inner=10
gaps_outer=5

[polybar]
height=27
show_cpu=1
show_memory=1

[picom]
corner_radius=10
blur=0

[audio]
pipewire_latency=balanced

[packages]
htop=1
btop=0
zellij=1

[services]
bluetooth=0
cups=0

[paths]
developer_dir=~/Developer
gamedev_dir=~/GameDev
studio_dir=~/Studio

[ui]
wizard_mode=hub
